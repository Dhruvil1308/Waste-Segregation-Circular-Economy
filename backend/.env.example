# Copy to .env and fill in your own values. Never commit .env.
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: only set if you want vision on a different model than OPENAI_MODEL
# OPENAI_VISION_MODEL=gpt-4o-mini

# Secret used to sign JWTs. Generate your own with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=generate-your-own-do-not-reuse-this-line
